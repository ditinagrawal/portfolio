---
import logoStar from '../assets/logo-star.svg'
import { author } from '../sample'

const socials = [
  { icon: 'ri-twitter-x-line', link: author.x },
  { icon: 'ri-linkedin-box-line', link: author.linkedin },
  { icon: 'ri-github-line', link: author.github },
]

---

<footer class="border-t-4 px-5 md:px-0 py-10 mt-30">
    <div class="max-w-4xl mx-auto">
      <!-- Main footer content -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <!-- Logo and brand -->
        <div class="text-center md:text-left">
          <a href="/" class="flex items-center gap-3 text-xl font-bold justify-center md:justify-start mb-3">
            <img src={logoStar.src} alt="logo" width="30" /> {author.nickname}
          </a>
          <p class="text-gray-600">Fullstack Developer & Engineer</p>
          {author.availableForWork && (
            <div class="flex items-center gap-2 mt-2 justify-center md:justify-start">
              <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
              <span class="text-sm text-green-600 font-semibold mt-1">Available for work</span>
            </div>
          )}
        </div>

        <!-- Quick contact -->
        <div class="text-center">
          <h4 class="font-bold mb-3">Quick Contact</h4>
          <div class="space-y-2 text-sm">
            <a href={author.email} class="block hover:text-blue-600 transition-colors">
              {author.email.replace('mailto:', '')}
            </a>
            <a href={`tel:${author.phone}`} class="block hover:text-green-600 transition-colors">
              {author.phone}
            </a>
            <p class="text-gray-600">{author.address}</p>
          </div>
        </div>

        <!-- Social links -->
        <div class="text-center md:text-right">
          <h4 class="font-bold mb-3">Connect</h4>
          <div class="flex justify-center md:justify-end gap-4">
            {socials.map(item => ( 
              <a href={item.link} target="_blank" 
                 class="w-10 h-10 border-2 border-gray-300 rounded flex items-center justify-center hover:border-black hover:bg-black hover:text-white transition-all duration-200">
                <i class={`${item.icon} text-lg`}></i>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Copyright -->
      <div class="border-t-2 border-gray-200 pt-6 text-center">
        <p class="text-gray-600">© {new Date().getFullYear()} {author.nickname}. All rights reserved.</p>
      </div>
    </div>
   </footer>